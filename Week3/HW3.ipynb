    "   },\n",
    "   \"source\": [\n",
    "    \"# Question 2  \\n\",\n",
    "    \"# create a dictionary comprehension to stuff the keys (ks) and values (vs) into a dictionary\\n\",\n",
    "    \"# be sure to keep the comprehension flexible to accommodate other lengths of pairs\\n\",\n",
    "    \"# this one has a length of 7, but the pairs could be longer or shorter\\n\",\n",
    "    \"# show/print the dictionary with each key/value pair on its own line\\n\",\n",
    "    \"\\n\",\n",
    "    \"ks = ['Alice', 'Bob', 'Charlie', 'David', 'Evan', 'Freddy', 'Gloria']\\n\",\n",
    "    \"vs = ['412 Maple St', '1536 Oak Dr', '789 Pine Way', '101 Birch St', '206 Cedar Ave', '13 Elm St', '3616 Spruce Pl']\\n\",\n",
    "    \"\\n\",\n",
    "    \"dictOne = {ks:vs for (ks,vs) in zip(ks,vs)}\\n\",\n",
    "    \"for key,value in dictOne.items():\\n\",\n",
    "    \"    print(key,value)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Alice 412 Maple St\\n\",\n",
    "      \"Bob 1536 Oak Dr\\n\",\n",
    "      \"Charlie 789 Pine Way\\n\",\n",
    "      \"David 101 Birch St\\n\",\n",
    "      \"Evan 206 Cedar Ave\\n\",\n",
    "      \"Freddy 13 Elm St\\n\",\n",
    "      \"Gloria 3616 Spruce Pl\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2025-02-06T11:22:57.442883Z\",\n",
    "     \"start_time\": \"2025-02-06T11:22:57.428897Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Question 3   \\n\",\n",
    "    \"# create a custom function that converts miles per gallon to l/100km\\n\",\n",
    "    \"# and round the value to 3 decimal places.\\n\",\n",
    "    \"\\n\",\n",
    "    \"# print the results testing the function with the following values\\n\",\n",
    "    \"# enter only the numeric part, you can exclude the \\\"mpg\\\" string from the actual call\\n\",\n",
    "    \"\\n\",\n",
    "    \"def conversionFunc(mpg):\\n\",\n",
    "    \"    #Miles to Kilometer = 1 -> 1.609\\n\",\n",
    "    \"    #Gallon to Liter = 1 -> 3.785\\n\",\n",
    "    \"    Lper100km = 100 / ((mpg * 1.609) / 3.785)\\n\",\n",
    "    \"    print(f\\\"{mpg} mpg converted to L/100km is \\\", round(Lper100km, 3))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# print the results testing the function on:\\n\",\n",
    "    \"# (a) 12.3 mpg\\n\",\n",
    "    \"\\n\",\n",
    "    \"conversionFunc(12.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (b) 35 mpg\\n\",\n",
    "    \"\\n\",\n",
    "    \"conversionFunc(35)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (c) 115 mpg\\n\",\n",
    "    \"\\n\",\n",
    "    \"conversionFunc(115)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"12.3 mpg converted to L/100km is  19.125\\n\",\n",
    "      \"35 mpg converted to L/100km is  6.721\\n\",\n",
    "      \"115 mpg converted to L/100km is  2.046\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 3\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2025-02-06T11:22:57.645698Z\",\n",
    "     \"start_time\": \"2025-02-06T11:22:57.453463Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Question 4  \\n\",\n",
    "    \"# create a custom function that separates and sums a 4 digit number.\\n\",\n",
    "    \"# for instance 3141 is 3+1+4+1 = 9\\n\",\n",
    "    \"# first of all, use a test to determine if the number is 4 digits long\\n\",\n",
    "    \"# all of the inputs will be integers, so don't worry about testing for strings, floats, etc\\n\",\n",
    "    \"# if the number is not 4 digits long return \\\"the input is not 4 digits\\\"\\n\",\n",
    "    \"# otherwise return a statement like \\\"the sum of 3141 is 9\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def numberLengthTest(numberInput):\\n\",\n",
    "    \"    if len(str(numberInput)) == 4:\\n\",\n",
    "    \"        total = sum(map(int, str(numberInput)))\\n\",\n",
    "    \"        print(f\\\"the sum of {numberInput} is {total}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"the input is not 4 digits\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# print the results testing the function on:\\n\",\n",
    "    \"# (a) 3141\\n\",\n",
    "    \"\\n\",\n",
    "    \"numberLengthTest(3141)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (b) 111\\n\",\n",
    "    \"\\n\",\n",
    "    \"numberLengthTest(111)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (c) 5827\\n\",\n",
    "    \"\\n\",\n",
    "    \"numberLengthTest(5827)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (d) 9998\\n\",\n",
    "    \"\\n\",\n",
    "    \"numberLengthTest(9998)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (e) 15122\\n\",\n",
    "    \"\\n\",\n",
    "    \"numberLengthTest(15122)\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"the sum of 3141 is 9\\n\",\n",
    "      \"the input is not 4 digits\\n\",\n",
    "      \"the sum of 5827 is 22\\n\",\n",
    "      \"the sum of 9998 is 35\\n\",\n",
    "      \"the input is not 4 digits\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2025-02-06T11:22:58.013750Z\",\n",
    "     \"start_time\": \"2025-02-06T11:22:57.675963Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Question 5   \\n\",\n",
    "    \"# create a custom function that converts temperatures from F to C or C to F\\n\",\n",
    "    \"# the function should take 2 arguments, the temperature and the unit it is currently in.\\n\",\n",
    "    \"# use an if statement to handle each of the units\\n\",\n",
    "    \"# return the converted value and the new unit\\n\",\n",
    "    \"# test the function on these values below.\\n\",\n",
    "    \"\\n\",\n",
    "    \"def convertTemps(temp, unit):\\n\",\n",
    "    \"    if unit == \\\"F\\\":\\n\",\n",
    "    \"        celsiusTemp = (temp - 32) * 5 / 9\\n\",\n",
    "    \"        print(f\\\"{temp}F converted to celsius is \\\", round(celsiusTemp, 2), \\\"C\\\")\\n\",\n",
    "    \"    elif unit == \\\"C\\\":\\n\",\n",
    "    \"        fahrenheitTemp = temp * 9 / 5 + 32\\n\",\n",
    "    \"        print(f\\\"{temp}C converted to fahrenheit is \\\", round(fahrenheitTemp, 2), \\\"C\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        return \\\"Invalid unit\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (a) 0F\\n\",\n",
    "    \"\\n\",\n",
    "    \"convertTemps(0, \\\"F\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (b) 0C\\n\",\n",
    "    \"\\n\",\n",
    "    \"convertTemps(0, \\\"C\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (c) 96F\\n\",\n",
    "    \"\\n\",\n",
    "    \"convertTemps(96, \\\"F\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (d) 100C\\n\",\n",
    "    \"\\n\",\n",
    "    \"convertTemps(100, \\\"C\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \" \"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"0F converted to celsius is  -17.78 C\\n\",\n",
    "      \"0C converted to fahrenheit is  32.0 C\\n\",\n",
    "      \"96F converted to celsius is  35.56 C\\n\",\n",
    "      \"100C converted to fahrenheit is  212.0 C\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
