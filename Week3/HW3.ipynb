    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Question 1  \\n\",\n",
    "    \"# create an if-else statement that tests a string as a password.\\n\",\n",
    "    \"# first test for length, the string should be 8 or more characters in length.\\n\",\n",
    "    \"# it should include at least 1 digit.\\n\",\n",
    "    \"# print a result of the test\\n\",\n",
    "    \"# the statement should return \\\"password OK\\\", if all elements are met\\n\",\n",
    "    \"# or explain why the password fails in the order above (length or digit)\\n\",\n",
    "    \"# it may fail on multiple tests - just report on the first failure in the above order\\n\",\n",
    "    \"\\n\",\n",
    "    \"# NOTE: This would be easier to write as a function for testing multiple strings\\n\",\n",
    "    \"# focus on the if-else statement for this question and don't worry about a function\\n\",\n",
    "    \"\\n\",\n",
    "    \"# create a base if-else statement here:\\n\",\n",
    "    \"\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"def passwordTest(password):\\n\",\n",
    "    \"    if len(password) >= 8 and re.search(r'\\\\d', password):\\n\",\n",
    "    \"        print(\\\"password OK.\\\")\\n\",\n",
    "    \"    elif len(password) < 8:\\n\",\n",
    "    \"        print(\\\"This password is too short. It must be at least 8 characters long.\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(\\\"This password needs at least one digit.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# test the strings by pasting your statement below 3 times to test each string:\\n\",\n",
    "    \"# (a) \\\"pass\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"passwordTest(\\\"pass\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (b) \\\"password\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"passwordTest(\\\"password\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (c) \\\"pas5w0rD\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"passwordTest(\\\"pas5w0rD\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# (d) \\\"pa5$w0rd+!\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"passwordTest(\\\"pa5$w0rd+!\\\")\\n\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"This password is too short. It must be at least 8 characters long.\\n\",\n",
    "      \"This password needs at least one digit.\\n\",\n",
    "      \"password OK.\\n\",\n",
    "      \"password OK.\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
